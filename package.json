{
  "name": "taskify",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "npm run dev:all",
    "start": "node server/server.js",
    "build": "npm run build --prefix client",
    "vercel-build": "npm run build",
    "server": "node server/server.js",
    "server:dev": "nodemon server/server.js",
    "client": "npm run dev --prefix client",
    "dev:all": "concurrently \"npm run server:dev\" \"npm run client\"",
    "dev:ll": "npm run dev:all",
    "lint": "eslint \"server/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "node --test server/tests/*.test.js",
    "test:watch": "node --test --watch server/tests/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "nodemon": "^3.0.1"
  }
}
