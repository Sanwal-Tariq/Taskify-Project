
# SMTP configuration (required to send real emails)
# For Gmail use App Password (enable 2FA and generate App Password for Mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: client URL used in welcome email
CLIENT_URL=http://localhost:5173

# Other important env vars (already required by the app)
# JWT_SECRET=your_jwt_secret
# MONGO_URI=mongodb://localhost:27017/taskify
# NODE_ENV=development
# PORT=3000
